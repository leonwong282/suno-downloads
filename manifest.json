{
  "manifest_version": 3,
  "name": "Suno Batch Downloader (MVP)",
  "version": "0.1.0",
  "description": "Milestone A prototype: extract visible songs on suno.com and download one track.",
  "permissions": [
    "downloads",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://suno.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Suno Downloader"
  },
  "content_scripts": [
    {
      "matches": [
        "https://suno.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
